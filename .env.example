# Copy this file to .env and fill in your Neon connection strings.
# Get both URLs from: https://console.neon.tech → your project → Connection Details
# Switch the dropdown to "Prisma" to get the exact format below.

# Pooled connection — used by the app at runtime (goes through Neon's PgBouncer)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection — used only by `prisma db push` and migrations (bypasses pooler)
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
